{
  "name": "harness-lab",
  "version": "0.1.0",
  "description": "Local CLI for creating inspectable prompt-harness run folders from YAML definitions.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "harness-lab": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "dev": "tsx src/cli.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "node dist/cli.js",
    "test": "node --test --import tsx tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "validate:harnesses": "tsx src/cli.ts validate",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "harnesses",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "keywords": [
    "agents",
    "agent-harness",
    "harness",
    "prompt-engineering",
    "ai-workflows",
    "llm"
  ],
  "author": "Brandon Carneiro",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sommbc/harness-lab.git"
  },
  "bugs": {
    "url": "https://github.com/sommbc/harness-lab/issues"
  },
  "homepage": "https://github.com/sommbc/harness-lab#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "js-yaml": "^4.2.0"
  }
}
